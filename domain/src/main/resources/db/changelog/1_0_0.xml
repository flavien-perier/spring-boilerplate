<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="1.0.0-create-table-app_user" author="perier@flavien.io">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="app_user"/>
      </not>
    </preConditions>

    <createTable tableName="app_user">
      <column name="user_id" type="UUID" defaultValueComputed="gen_random_uuid()">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="email" type="VARCHAR(100)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="password" type="VARCHAR(130)">
        <constraints nullable="false"/>
      </column>
      <column name="proof_of_work" type="VARCHAR(130)">
        <constraints nullable="false"/>
      </column>
      <column name="password_salt" type="VARCHAR(10)">
        <constraints nullable="false"/>
      </column>
      <column name="otp_secret" type="VARCHAR(50)">
        <constraints nullable="true"/>
      </column>
      <column name="enabled" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="last_login" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="deletion_warning_sent_at" type="TIMESTAMP">
        <constraints nullable="true"/>
      </column>
      <column name="update_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="creation_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createIndex tableName="app_user" indexName="index_app_user_email">
      <column name="email"/>
    </createIndex>
  </changeSet>

  <changeSet id="1.0.0-create-table-app_role" author="perier@flavien.io">
    <createTable tableName="app_role">
      <column name="role_id" type="UUID" defaultValueComputed="gen_random_uuid()">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(100)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="parent_id" type="UUID">
        <constraints nullable="true" foreignKeyName="fk_app_role_parent" referencedTableName="app_role"
                     referencedColumnNames="role_id"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="1.0.0-create-table-user_role" author="perier@flavien.io">
    <createTable tableName="user_role">
      <column name="user_id" type="UUID">
        <constraints nullable="false" primaryKey="true" foreignKeyName="fk_user_role_user"
                     referencedTableName="app_user" referencedColumnNames="user_id"/>
      </column>
      <column name="role_id" type="UUID">
        <constraints nullable="false" primaryKey="true" foreignKeyName="fk_user_role_role"
                     referencedTableName="app_role" referencedColumnNames="role_id"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="1.0.0-create-table-permission" author="perier@flavien.io">
    <createTable tableName="permission">
      <column name="name" type="VARCHAR(50)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="1.0.0-create-table-user_permission" author="perier@flavien.io">
    <createTable tableName="user_permission">
      <column name="user_id" type="UUID">
        <constraints nullable="false" primaryKey="true" foreignKeyName="fk_user_permission_user"
                     referencedTableName="app_user" referencedColumnNames="user_id"/>
      </column>
      <column name="permission_name" type="VARCHAR(50)">
        <constraints nullable="false" primaryKey="true" foreignKeyName="fk_user_permission_permission"
                     referencedTableName="permission" referencedColumnNames="name"/>
      </column>
      <column name="allow" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="1.0.0-create-table-role_permission" author="perier@flavien.io">
    <createTable tableName="role_permission">
      <column name="role_id" type="UUID">
        <constraints nullable="false" primaryKey="true" foreignKeyName="fk_role_permission_role"
                     referencedTableName="app_role" referencedColumnNames="role_id"/>
      </column>
      <column name="permission_name" type="VARCHAR(50)">
        <constraints nullable="false" primaryKey="true" foreignKeyName="fk_role_permission_permission"
                     referencedTableName="permission" referencedColumnNames="name"/>
      </column>
      <column name="allow" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="1.0.0-insert-permissions" author="perier@flavien.io">
    <insert tableName="permission">
      <column name="name" value="MANAGE_OWN_ACCOUNT"/>
    </insert>
    <insert tableName="permission">
      <column name="name" value="MANAGE_OWN_SESSIONS"/>
    </insert>
    <insert tableName="permission">
      <column name="name" value="MANAGE_ALL_USERS"/>
    </insert>
  </changeSet>

  <changeSet id="1.0.0-insert-default-user" author="perier@flavien.io">
    <insert tableName="app_user">
      <column name="user_id" value="00000000-0000-7000-8000-000000000000"/>
      <column name="email" value="perier@flavien.io"/>
      <column name="password" value="_"/>
      <column name="proof_of_work" value="_"/>
      <column name="password_salt" value="_"/>
      <column name="enabled" valueBoolean="true"/>
      <column name="last_login" valueComputed="CURRENT_TIMESTAMP"/>
    </insert>
  </changeSet>

  <changeSet id="1.0.0-insert-default-roles" author="perier@flavien.io">
    <insert tableName="app_role">
      <column name="role_id" value="00000000-0000-7000-8000-000000000001"/>
      <column name="name" value="USER"/>
    </insert>
    <insert tableName="app_role">
      <column name="role_id" value="00000000-0000-7000-8000-000000000002"/>
      <column name="name" value="ADMIN"/>
      <column name="parent_id" value="00000000-0000-7000-8000-000000000001"/>
    </insert>
  </changeSet>

  <changeSet id="1.0.0-insert-default-role-permission" author="perier@flavien.io">
    <insert tableName="role_permission">
      <column name="role_id" value="00000000-0000-7000-8000-000000000001"/>
      <column name="permission_name" value="MANAGE_OWN_ACCOUNT"/>
      <column name="allow" valueBoolean="true"/>
    </insert>
    <insert tableName="role_permission">
      <column name="role_id" value="00000000-0000-7000-8000-000000000001"/>
      <column name="permission_name" value="MANAGE_OWN_SESSIONS"/>
      <column name="allow" valueBoolean="true"/>
    </insert>
    <insert tableName="role_permission">
      <column name="role_id" value="00000000-0000-7000-8000-000000000002"/>
      <column name="permission_name" value="MANAGE_ALL_USERS"/>
      <column name="allow" valueBoolean="true"/>
    </insert>
  </changeSet>

  <changeSet id="1.0.0-insert-default-user-role" author="perier@flavien.io">
    <insert tableName="user_role">
      <column name="user_id" value="00000000-0000-7000-8000-000000000000"/>
      <column name="role_id" value="00000000-0000-7000-8000-000000000002"/>
    </insert>
  </changeSet>

  <changeSet id="1.0.0-insert-permission-manage-all-roles" author="perier@flavien.io">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM permission WHERE name = 'MANAGE_ALL_ROLES'
      </sqlCheck>
    </preConditions>

    <insert tableName="permission">
      <column name="name" value="MANAGE_ALL_ROLES"/>
    </insert>
  </changeSet>

  <changeSet id="1.0.0-grant-manage-all-roles-to-admin" author="perier@flavien.io">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM role_permission
        WHERE permission_name = 'MANAGE_ALL_ROLES'
          AND role_id = '00000000-0000-7000-8000-000000000002'
      </sqlCheck>
    </preConditions>

    <insert tableName="role_permission">
      <column name="role_id" value="00000000-0000-7000-8000-000000000002"/>
      <column name="permission_name" value="MANAGE_ALL_ROLES"/>
      <column name="allow" valueBoolean="true"/>
    </insert>
  </changeSet>
</databaseChangeLog>