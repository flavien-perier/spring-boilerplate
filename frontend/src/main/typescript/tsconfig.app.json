{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.json",
    "src/**/*.vue"
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "isolatedModules": false,
    "resolveJsonModule" : true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "noEmit": false,
    "types": [
      "node",
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@generated/component-library/style.css": ["./generated/component-library/component-library.es.css"],
      "@generated/component-library": ["./generated/component-library/src/index.d.ts"],
      "@generated/api": ["./generated/api"],
      "@generated/utils": ["./generated/utils"],
    }
  }
}
